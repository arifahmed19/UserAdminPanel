@{
    Layout = "_LayoutAuth";
}

@model UserAdminPanel.Models.RegisterViewModel

<section class="bg-light" style="width: 100%; min-height: 100vh;">
    <div class="row g-0 flex-lg-row-reverse" style="min-height: 100vh;">
        <div class="col-lg-6 d-flex align-items-center justify-content-center">
            <div style="width: 100%; max-width: 500px; padding: 20px;">
                <div class="card-body p-md-5" style="border: 1px solid #dee2e6; border-radius: 0.5rem; background: white;">
                                <div class="text-center">
                                    <img src="~/images/nitrogensports-logo.svg" style="width: 185px; max-width: 100%;" alt="logo">
                                    <h4 class="mt-3 mb-4 pb-1">Create Account</h4>
                                </div>

                                <form asp-action="Register" method="post">
                                    <div class="form-outline mb-3">
                                        <label class="form-label" asp-for="Name">Full Name</label>
                                        <input asp-for="Name" class="form-control" />
                                    </div>

                                    <div class="form-outline mb-3">
                                        <label class="form-label" asp-for="Email">Email Address</label>
                                        <input asp-for="Email" class="form-control" />
                                    </div>

                                    <div class="form-outline mb-4">
                                        <label class="form-label" asp-for="Password">Password</label>
                                        <input asp-for="Password" type="password" class="form-control" />
                                    </div>

                                    <div class="text-center pt-1 mb-4 pb-1">
                                        <button class="btn btn-primary btn-block mb-3 w-100 py-2" type="submit">
                                            Register Now
                                        </button>
                                    </div>

                                    <div class="d-flex flex-column flex-sm-row align-items-center justify-content-center pb-4">
                                        <p class="mb-0 me-sm-2 mb-2 mb-sm-0">Already have an account?</p>
                                        <a asp-action="Login" class="btn btn-outline-secondary">Sign In</a>
                                    </div>
                                </form>
                </div>
            </div>
        </div>
        <div class="col-lg-6 bg-dark d-none d-lg-flex align-items-center justify-content-center">
            <div class="text-white px-3 py-4 p-md-5 mx-md-4 text-white-shadow" style="max-width: 400px;">
                <h4 class="mb-4">Join the Administration</h4>
                <p class="small mb-0">Experience the power of secure user management. Create your account today and gain access to the real-time status dashboard and bulk management tools.</p>
            </div>
        </div>
    </div>
</section>
